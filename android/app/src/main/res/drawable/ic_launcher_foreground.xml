<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 自适应图标要求：图标内容应在中心66dp的安全区域内 -->
    <!-- 总尺寸108dp，留出21dp边距确保图标不被裁切 -->
    <item
        android:width="66dp"
        android:height="66dp"
        android:left="21dp"
        android:top="21dp"
        android:right="21dp"
        android:bottom="21dp"
        android:gravity="center">
        <bitmap android:src="@drawable/logo_new" />
    </item>
</layer-list>
